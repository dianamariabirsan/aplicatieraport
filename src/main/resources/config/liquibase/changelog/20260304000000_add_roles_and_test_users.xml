            <column name="last_modified_by" value="system"/>
        </insert>
    </changeSet>

    <!-- Assign ROLE_USER to test users -->
    <changeSet id="20260304000000-7" author="jhipster">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">SELECT COUNT(*) FROM jhi_user_authority ua JOIN jhi_user u ON ua.user_id = u.id WHERE u.login = 'medic' AND ua.authority_name = 'ROLE_USER'</sqlCheck>
        </preConditions>
        <insert tableName="jhi_user_authority">
            <column name="user_id" valueComputed="(SELECT id FROM jhi_user WHERE login = 'medic')"/>
            <column name="authority_name" value="ROLE_USER"/>
        </insert>
    </changeSet>

    <changeSet id="20260304000000-8" author="jhipster">
