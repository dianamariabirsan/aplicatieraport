<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Add new role authorities -->
    <changeSet id="20260304000000-1" author="jhipster">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">SELECT COUNT(*) FROM jhi_authority WHERE name = 'ROLE_MEDIC'</sqlCheck>
        </preConditions>
        <insert tableName="jhi_authority">
            <column name="name" value="ROLE_MEDIC"/>
        </insert>
    </changeSet>

    <changeSet id="20260304000000-2" author="jhipster">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">SELECT COUNT(*) FROM jhi_authority WHERE name = 'ROLE_FARMACIST'</sqlCheck>
        </preConditions>
        <insert tableName="jhi_authority">
            <column name="name" value="ROLE_FARMACIST"/>
        </insert>
    </changeSet>

    <changeSet id="20260304000000-3" author="jhipster">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">SELECT COUNT(*) FROM jhi_authority WHERE name = 'ROLE_PACIENT'</sqlCheck>
        </preConditions>
        <insert tableName="jhi_authority">
            <column name="name" value="ROLE_PACIENT"/>
        </insert>
    </changeSet>

    <!-- Add test users: medic, farmacist, pacient with password hash for '1234' (dev/test only).
         WARNING: Use strong passwords in production. These accounts use a shared weak password
         intended only for local development and testing. -->
    <changeSet id="20260304000000-4" author="jhipster">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">SELECT COUNT(*) FROM jhi_user WHERE login = 'medic'</sqlCheck>
        </preConditions>
        <insert tableName="jhi_user">
            <column name="id" valueNumeric="3"/>
            <column name="login" value="medic"/>
            <column name="password_hash" value="$2b$10$MHCYoN.cmBOYl1G2E4bCp.W0ARe9XCuyjUjVvptuuUI7PVyEDsShe"/>
            <column name="first_name" value="Medic"/>
            <column name="last_name" value="Test"/>
            <column name="email" value="medic@localhost"/>
            <column name="activated" valueBoolean="true"/>
            <column name="lang_key" value="ro"/>
            <column name="created_by" value="system"/>
            <column name="last_modified_by" value="system"/>
        </insert>
    </changeSet>

    <changeSet id="20260304000000-5" author="jhipster">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">SELECT COUNT(*) FROM jhi_user WHERE login = 'farmacist'</sqlCheck>
        </preConditions>
        <insert tableName="jhi_user">
            <column name="id" valueNumeric="4"/>
            <column name="login" value="farmacist"/>
            <column name="password_hash" value="$2b$10$MHCYoN.cmBOYl1G2E4bCp.W0ARe9XCuyjUjVvptuuUI7PVyEDsShe"/>
            <column name="first_name" value="Farmacist"/>
            <column name="last_name" value="Test"/>
            <column name="email" value="farmacist@localhost"/>
            <column name="activated" valueBoolean="true"/>
            <column name="lang_key" value="ro"/>
            <column name="created_by" value="system"/>
            <column name="last_modified_by" value="system"/>
        </insert>
    </changeSet>

    <changeSet id="20260304000000-6" author="jhipster">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">SELECT COUNT(*) FROM jhi_user WHERE login = 'pacient'</sqlCheck>
        </preConditions>
        <insert tableName="jhi_user">
            <column name="id" valueNumeric="5"/>
            <column name="login" value="pacient"/>
            <column name="password_hash" value="$2b$10$MHCYoN.cmBOYl1G2E4bCp.W0ARe9XCuyjUjVvptuuUI7PVyEDsShe"/>
