<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260302230000-1" author="healthapp">
        <addColumn tableName="decision_log">
            <column name="final_decision" type="varchar(500)">
                <constraints nullable="true"/>
            </column>
            <column name="decision_source" type="varchar(255)">
                <constraints nullable="true"/>
            </column>
            <column name="override_reason" type="varchar(500)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>
